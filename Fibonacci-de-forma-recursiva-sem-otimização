#include <stdio.h>

long long chamadas = 0;
long long fibonacci (int n){
    chamadas++;
    if (n == 0) return 0;
    if (n == 1) return 1;
    return fibonacci(n - 1) + fibonacci(n - 2);
}

int main (){
    int termos;
    printf ("digite um numero inteiro para vermos sequência do seu fibonacci: ");
    scanf ("%d", &termos);
    
    printf ("Sequencia de fibonacci é ");
    
    for (int i = 0; i < termos; i++) {
        printf("%lld ", fibonacci(i));
    }
     printf ("\na quantida de chamandas recursicas foi: %lld", chamadas);
    return 0;
}
