#include <stdio.h>
#include <stdlib.h>

/*
 * CASO BASE: Quando n == 1, apenas mova o disco da origem para o destino
 * REDUÇÃO DO PROBLEMA: Para mover n discos:
 *   1. Move n-1 discos de origem para auxiliar (usando destino como auxiliar)
 *   2. Move o disco maior (n-ésimo) de origem para destino
 *   3. Move n-1 discos de auxiliar para destino (usando origem como auxiliar)
 */

typedef struct {
    long long movimentos;
} Contador;

void hanoi(int n, char origem, char destino, char auxiliar, Contador *contador) {
    // CASO BASE: um único disco é movido diretamente
    if (n == 1) {
        printf("Mover disco 1 de %c para %c\n", origem, destino);
        contador->movimentos++;
        return;
    }
    
    // REDUÇÃO: Move n-1 discos de origem para auxiliar
    hanoi(n - 1, origem, auxiliar, destino, contador);
    
    // Move o maior disco de origem para destino
    printf("Mover disco %d de %c para %c\n", n, origem, destino);
    contador->movimentos++;
    
    // REDUÇÃO: Move n-1 discos de auxiliar para destino
    hanoi(n - 1, auxiliar, destino, origem, contador);
}

int main() {
    int n;
    
    printf("=== TORRES DE HANOI ===\n");
    printf("Digite a quantidade de discos: ");
    scanf("%d", &n);
    
    if (n <= 0) {
        printf("Quantidade de discos deve ser positiva!\n");
        return 1;
    }
    
    // Aloca estrutura para contabilizar movimentos
    Contador *contador = (Contador *)malloc(sizeof(Contador));
    if (contador == NULL) {
        printf("Erro na alocação de memória!\n");
        return 1;
    }
    contador->movimentos = 0;
    
    printf("\n--- Sequência de movimentos ---\n");
    hanoi(n, 'A', 'C', 'B', contador);
    
    printf("\n--- Resultado ---\n");
    printf("Total de movimentos: %lld\n", contador->movimentos);
    printf("Verificação: 2^%d - 1 = %lld\n", n, (1LL << n) - 1);
    
    free(contador);
    return 0;
}
